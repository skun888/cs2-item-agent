{
  "name": "cs2-item-agent",
  "version": "0.8.0-alpha.1",
  "description": "Local-first, model-agnostic CS2 market and inventory decision assistant.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "check": "npm run typecheck && npm test",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/src/cli/index.js",
    "mcp": "node scripts/run-mcp.mjs",
    "mcp:dev": "tsx src/mcp/index.ts",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "release:verify": "npm run check && npm run smoke:mcp",
    "audit:steamdt-inspect": "tsx scripts/audit-steamdt-inspect.ts",
    "db:migrate": "npm run dev -- db migrate"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@csfloat/cs2-inspect-serializer": "^1.1.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sharp": "^0.35.3",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  }
}
