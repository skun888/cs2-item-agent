# Required for SteamDT market-data commands.
STEAMDT_API_KEY=

# Optional. Keep the official endpoint unless testing a compatible adapter.
STEAMDT_BASE_URL=https://open.steamdt.com

# Optional. Enables CSQAQ personal-permission audits and enrichment data.
# Register and bind your current public IP before use. Never commit a real token.
CSQAQ_API_TOKEN=
CSQAQ_BASE_URL=https://api.csqaq.com

# Optional. Public inventory endpoint; no Steam password, Cookie, or Publisher Key is used.
STEAM_COMMUNITY_BASE_URL=https://steamcommunity.com

# Optional for networks that cannot directly reach Steam Community.
# Example local HTTP proxy: http://127.0.0.1:7890
STEAM_PROXY_URL=

# Optional. Used when a watch does not specify its own interval.
INVENTORY_DEFAULT_INTERVAL_MINUTES=30

# Optional inventory valuation defaults. Rates use decimals: 0.20 = 20%.
INVENTORY_PRICE_CACHE_MINUTES=30
INVENTORY_HIGH_VALUE_ITEM_CNY=1000
INVENTORY_LARGE_CHANGE_CNY=10000
INVENTORY_LARGE_CHANGE_RATE=0.20
INVENTORY_MINIMUM_PRICE_COVERAGE=0.90

# Optional. Market alert worker interval in minutes.
ALERT_DEFAULT_INTERVAL_MINUTES=30

# Optional. Defaults to ./data.
CS2_ITEM_AGENT_DATA_DIR=./data

# Optional. Enterprise WeChat bot webhook; never commit a real webhook.
WECHAT_WEBHOOK_URL=

# Optional: debug | info | warn | error
LOG_LEVEL=info

# Optional. Copy the example before editing; conclusions echo the actual parameters used.
# FEE_TEMPLATE_PATH=./local/fee-template.json
